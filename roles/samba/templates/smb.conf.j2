# smb.conf — {{ server.hostname }} — gerado pelo Ansible em {{ ansible_date_time.date }}
# NÃO edite manualmente; use o Ansible ou o painel web para mudanças permanentes.

[global]
    workgroup            = {{ samba.workgroup }}
    server string        = {{ server.hostname }} File Server
    netbios name         = {{ server.hostname | upper }}
    server role          = standalone server
    security             = user
    passdb backend       = tdbsam
    map to guest         = bad user

    # Administradores Samba — bypass de permissões de share
    admin users          = {{ server.admin_user }}{% for u in samba.extra_admins %} {{ u }}{% endfor %}

    interfaces           = lo {{ server.iface }}
    bind interfaces only = yes
    # Cobre as faixas privadas e as legadas CDPNI (172.14.x já dentro de
    # 172.; 192.14.29. precisa ser explícita pois 192.168. não a cobre)
    hosts allow          = 127.0.0.1 10. 172. 192.168. 192.14.29.
    hosts deny           = ALL

    min protocol         = SMB2
    max protocol         = SMB3
    use sendfile         = yes
    aio read size        = 16384
    aio write size       = 16384
    read raw             = yes
    write raw            = yes
    max xmit             = 65535
    dead time            = 15
    oplocks              = no
    level2 oplocks       = no
    kernel oplocks       = no
    smb2 leases          = no
    change notify        = yes
    kernel change notify = yes

    log file             = {{ samba.log_dir }}/log.%m
    max log size         = 51200
    log level            = 1 auth:2

    create mask          = 0664
    directory mask       = 0750
    force create mode    = 0664
    force directory mode = 0750

    load printers        = no
    printing             = bsd
    printcap name        = /dev/null
    disable spoolss      = yes

    unix charset         = UTF-8
    dos charset          = CP850

    # Lixeira global — organizada por usuário/share para permitir a
    # restauração ao local de origem (página Lixeira do portal)
    vfs objects          = recycle full_audit
    recycle:repository   = {{ raid.mount }}/recycle/%U/%S
    recycle:keeptree     = yes
    # 0770 (não o padrão 0700): com bits de grupo a máscara de ACL não
    # anula o acesso de leitura do portal (página Lixeira)
    recycle:directory_mode = 0770
    recycle:subdir_mode  = 0770
    recycle:versions     = yes
    recycle:touch        = yes
    recycle:maxsize      = 1073741824
    recycle:exclude      = *.tmp *.temp ~$* .DS_Store Thumbs.db desktop.ini

    # Auditoria de acesso — vai para o syslog local5, que o rsyslog grava
    # em /var/log/samba/audit.log (lido pela página Logs do portal).
    # Samba >= 4.15 usa syscalls *at: open/rename/unlink viraram openat etc.
    full_audit:prefix    = %u|%I|%S
    # Só operações que representam ACESSO REAL a arquivos — sem connect/
    # disconnect (ruído de enumeração de shares pelo Windows). O portal
    # ainda filtra aberturas de pastas (navegação do Explorer).
    full_audit:success   = openat renameat unlinkat mkdirat
    full_audit:failure   = openat
    full_audit:facility  = local5
    full_audit:priority  = notice

[Recycle]
    comment     = Lixeira (restaure recortando de volta para o share)
    path        = {{ raid.mount }}/recycle
    valid users = {{ server.admin_user }}{% for u in samba.extra_admins %} {{ u }}{% endfor %}
    # writable: admins restauram por recortar/colar e podem esvaziar
    writable    = yes
    browseable  = no
    # a lixeira do próprio Recycle seria recursiva — desativa o vfs aqui
    vfs objects = full_audit

{% for share in samba_shares %}
{% set grp = share.group | default("grp_" + (share.name | lower)) %}
{% set share_path = raid.mount + '/shares/' + share.name %}

[{{ share.name }}]
    comment              = {{ share.name | replace('_', ' ') }}
    path                 = {{ share_path }}
    writable             = yes
    browseable           = {{ 'no' if share.type == 'guest_hidden' else 'yes' }}
    create mask          = 0664
    directory mask       = 0777
    force create mode    = 0664
    force directory mode = 0777
    force group          = {{ grp }}
{% if share.type in ['guest', 'guest_hidden'] %}
    guest ok             = yes
    public               = yes
{% elif share.type == 'restricted' %}
    guest ok             = no
    valid users          = @{{ grp }} {{ server.admin_user }}{% for u in samba.extra_admins %} {{ u }}{% endfor %}

{% else %}
    guest ok             = no
    valid users          = @{{ grp }} supervisao {{ server.admin_user }}{% for u in samba.extra_admins %} {{ u }}{% endfor %}

{% endif %}

{% endfor %}
