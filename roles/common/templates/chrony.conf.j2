# Gerenciado pelo Ansible — CDPNI
# Fonte preferida: o gateway (GWOS serve NTP para a LAN). Enquanto ele
# não existir/estiver fora, o pool ntp.br mantém o relógio certo — sem
# fonte nenhuma o clock deriva e o apt passa a rejeitar assinaturas
# ("Not live until ...").
server {{ server.gateway }} iburst prefer minpoll 4 maxpoll 6
pool pool.ntp.br iburst
driftfile /var/lib/chrony/drift
# Corrige diferenças grandes por salto (não só ajuste gradual),
# em qualquer momento — não apenas nas 3 primeiras medições
makestep 1.0 -1
rtcsync
