[cdpni-portal]
enabled  = true
port     = 443,80
filter   = cdpni-portal
logpath  = /var/log/cdpni_portal_access.log
maxretry = 5
bantime  = 1800
findtime = 300
# Apenas localhost é isento — a versão anterior isentava a LAN inteira,
# o que tornava a jail inútil (todos os clientes vêm da LAN).
ignoreip = 127.0.0.1/8
