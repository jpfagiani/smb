# DESATIVADA de propósito:
#  - o fail2ban não traz um filtro "samba" (filter.d/samba.conf não existe)
#  - o Samba loga por máquina (log.%m) — o logpath log.samba nunca existe
# Com filter/logpath inexistentes a jail quebra e pode impedir o fail2ban
# de iniciar. Para ativar de verdade seria preciso criar um filtro próprio
# e habilitar auth_audit no smb.conf.
[samba]
enabled  = false
port     = 445,139
protocol = tcp
filter   = samba
logpath  = /var/log/samba/log.%(__name__)s
maxretry = 5
bantime  = 3600
findtime = 600
ignoreip = 127.0.0.1/8
