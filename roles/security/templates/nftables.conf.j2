#!/usr/sbin/nft -f
# CDPNI — gerado pelo Ansible em {{ ansible_date_time.date }}
# Tabela nomeada "cdpni" para não colidir com o gateway GWOS
# na eventualidade de ambos rodarem no mesmo host.

flush ruleset

# ── Portas por serviço ────────────────────────────────────────────────────────
define SSH_PORT   = 22
define SMB_PORTS  = { 139, 445 }   # SMB/CIFS (TCP)
define NB_PORTS   = { 137, 138 }   # NetBIOS (UDP) — resolução de nomes Windows
define WEB_PORTS  = { 80, 443, 8443 }  # Portal (80→443) + painel admin (8443)
define FLASK_PORT = 5000           # Flask interno — apenas loopback

table inet cdpni {

    # ── Redes internas permitidas ─────────────────────────────────────────────
    # Definidas em group_vars/all.yml (network_ranges): faixas RFC 1918 +
    # faixas legadas CDPNI fora do espaço privado (172.14.29.0/24, 192.14.29.0/24).
    # auto-merge resolve sobreposições (ex.: 10.14.29.0/24 dentro de 10.0.0.0/8).
    set redes_internas {
        type ipv4_addr
        flags interval
        auto-merge
        elements = { {{ network_ranges | join(', ') }} }
    }

    # ── Conexões SSH recentes (anti-brute force) ──────────────────────────────
    # Permite no máximo 4 novas conexões SSH por minuto por IP de origem.
    set ssh_ratelimit {
        type ipv4_addr
        flags dynamic, timeout
        timeout 60s
    }

    chain input {
        type filter hook input priority filter; policy drop;

        # Descarta pacotes com estado inválido (TCP flags corrompidos, etc.)
        ct state invalid drop

        # Aceita respostas de conexões já estabelecidas
        ct state { established, related } accept

        # Loopback sempre liberado
        iifname "lo" accept

        # ── ICMP ─────────────────────────────────────────────────────────────
        # Ping e diagnóstico de rede (apenas redes internas)
        ip  protocol icmp   ip  saddr @redes_internas accept
        ip6 nexthdr  icmpv6 ip6 saddr ::/0             accept

        # ── SSH ───────────────────────────────────────────────────────────────
        # Rate-limit: máx 4 conexões novas/minuto por IP (bloqueia brute-force)
        tcp dport $SSH_PORT ip saddr @redes_internas \
            ct state new \
            add @ssh_ratelimit { ip saddr limit rate 4/minute } accept
        tcp dport $SSH_PORT ip saddr @redes_internas \
            ct state new drop

        # ── Samba SMB/CIFS (TCP) ─────────────────────────────────────────────
        tcp dport $SMB_PORTS ip saddr @redes_internas accept

        # ── Samba NetBIOS (UDP) ───────────────────────────────────────────────
        udp dport $NB_PORTS  ip saddr @redes_internas accept

        # ── Portal (80/443) e painel admin (8443) ────────────────────────────
        tcp dport $WEB_PORTS ip saddr @redes_internas accept

        # ── Flask interno ─────────────────────────────────────────────────────
        # Porta 5000 acessível apenas localmente (nginx faz o proxy para 443)
        tcp dport $FLASK_PORT ip saddr 127.0.0.1 accept

        # ── Drop com log (limite para não saturar o journal) ─────────────────
        limit rate 5/minute log prefix "nft-cdpni-drop: " flags all
        drop
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}
