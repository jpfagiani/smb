# Portal CDPNI — gerado pelo Ansible
SAMBA_ROOT  = '{{ raid.mount }}/shares'
ADMIN_USERS = ['{{ server.admin_user }}', 'cpd', 'supervisao']
SERVER_IP   = '{{ server.ip }}'
DOMAIN      = '{{ server.domain }}'
{# Persistida em arquivo: /dev/null gerava chave nova a cada run do
   playbook, derrubando todas as sessões logadas do portal. #}
SECRET_KEY  = '{{ lookup("password", portal.dir ~ "/.secret_key chars=ascii_letters,digits length=64") }}'
SESSION_COOKIE_HTTPONLY = True
SESSION_COOKIE_SECURE   = True
PERMANENT_SESSION_LIFETIME = 3600
MAX_CONTENT_LENGTH = 512 * 1024 * 1024
BACKUP_DIR     = '{{ backup.dir | default("/opt/backups") }}'
BACKUP_SCRIPT  = '{{ backup.script | default("/opt/scripts/backup.sh") }}'
